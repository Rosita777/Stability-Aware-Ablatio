# OpenAI-compatible endpoint for optional live reruns.
# Do not commit real keys.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Comma-separated model ids accepted by your endpoint.
MODEL_LIST=openai/gpt-4o-mini

# Public BFCL checkout paths for optional live reruns.
BFCL_ROOT=third_party/gorilla/berkeley-function-call-leaderboard
BFCL_DATA_DIR=third_party/gorilla/berkeley-function-call-leaderboard/bfcl_eval/data
